# Copy to `.env` for local dev, or `.env.production` for the deploy build.
# Only VITE_*-prefixed vars are exposed to the browser. These values are PUBLIC
# (baked into the bundle at build time) — never put secrets here.

VITE_API_URL_V1=http://127.0.0.1:8000/api/v1
VITE_REVERB_APP_KEY=your-reverb-app-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
